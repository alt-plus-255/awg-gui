# Panel
PANEL_PORT=8877
PANEL_HTTPS_PORT=7443
APP_URL=http://localhost:8877
APP_KEY=
APP_ENV=production
APP_DEBUG=false

# Admin (filled by awg-gui-install.sh)
ADMIN_PASSWORD=

# Database (DB_PASSWORD generated on install)
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=awggui
DB_USERNAME=awggui
DB_PASSWORD=

# AmneziaWG (prompted on install)
AWG_PORT=51820
SERVER_ENDPOINT=auto
INTERNAL_SUBNET=10.66.66.0/24
PEER_DNS=1.1.1.1
ALLOWED_IPS=0.0.0.0/0, ::/0
PERSISTENT_KEEPALIVE=25

# Laravel session / Sanctum (baseline; panel domain is configured in admin UI)
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
SESSION_DRIVER=database
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
CACHE_STORE=database
QUEUE_CONNECTION=database

# Container timezone (panel timezone is also stored in settings UI)
TZ=UTC
